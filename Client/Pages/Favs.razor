@page "/favs"
@using BlazorBootstrap
@using MyBirds.Shared.ViewModels
@using MyBirds.Client.Helpers
@inject HttpClient Http

<PageTitle>Favorites</PageTitle>

<h1>Favorites</h1>

@if (_favourites.Count == 0)
{
    <p>No favorite photos yet.</p>
}
else
{
    <div class="favs-grid" style="@($"--favs-columns: {Columns};")">
        @foreach (var fav in CurrentPageItems)
        {
            <NavLink href="@($"/species/{fav.SpeciesId}")" class="favs-tile-link">
                <img class="favs-image"
                     src="@PhotoLocator.GetPhotoUrl(fav.PhotoUrl, fav.ThumbnailUrl)"
                     width="360"
                     height="360"
                     loading="lazy"
                     decoding="async"
                     alt="@fav.SpeciesName" />
            </NavLink>
        }
    </div>

    @if (TotalPages > 1)
    {
        <div class="favs-pagination">
            <Pagination ActivePageNumber="@_currentPage"
                        TotalPages="@TotalPages"
                        DisplayPages="7"
                        Alignment="Alignment.Center"
                        PreviousLinkText="Prev"
                        NextLinkText="Next"
                        PageChanged="OnPageChangedAsync" />
        </div>
    }
}

@code {
    private const int PageSize = 18;
    private const int Columns = 6;

    private List<FavouritesViewModel> _favourites = [];
    private int _currentPage = 1;

    private int TotalPages => (int)Math.Ceiling(_favourites.Count / (double)PageSize);

    private IEnumerable<FavouritesViewModel> CurrentPageItems =>
        _favourites
            .Skip((_currentPage - 1) * PageSize)
            .Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<IEnumerable<FavouritesViewModel>>("favourites");
        _favourites = response?.ToList() ?? [];
    }

    private Task OnPageChangedAsync(int newPageNumber)
    {
        var normalizedPageNumber = Math.Clamp(newPageNumber, 1, Math.Max(1, TotalPages));
        _currentPage = normalizedPageNumber;
        return Task.CompletedTask;
    }
}
