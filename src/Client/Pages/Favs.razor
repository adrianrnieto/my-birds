@page "/favs"
@using BlazorBootstrap
@using MyBirds.Shared.ViewModels
@using MyBirds.Client.Helpers
@inject HttpClient Http

<PageTitle>Favorites</PageTitle>

<h1>Favorites</h1>

@if (_allFavourites.Count == 0)
{
    <p>No favorite photos yet.</p>
}
else
{
    <div class="favs-filters">
        <div class="filter-group">
            <label for="orderSelect" class="filter-label">Order:</label>
            <select id="orderSelect" class="filter-select" @onchange="OnOrderChangedAsync">
                <option value="">All Orders</option>
                @foreach (var order in _availableOrders)
                {
                    <option value="@order">@order</option>
                }
            </select>
        </div>

        <div class="filter-group">
            <label for="familySelect" class="filter-label">Family:</label>
            <select id="familySelect" class="filter-select" @onchange="OnFamilyChangedAsync">
                <option value="">All Families</option>
                @foreach (var family in _availableFamilies)
                {
                    <option value="@family">@family</option>
                }
            </select>
        </div>
    </div>

    <div class="favs-grid" style="@($"--favs-columns: {Columns};")">
        @foreach (var fav in CurrentPageItems)
        {
            <NavLink href="@($"/species/{fav.SpeciesId}")" class="favs-tile-link">
                <img class="favs-image"
                     src="@PhotoLocator.GetPhotoUrl(fav.PhotoUrl, fav.ThumbnailUrl)"
                     width="360"
                     height="360"
                     loading="lazy"
                     decoding="async"
                     alt="@fav.SpeciesName" />
            </NavLink>
        }
    </div>

    @if (TotalPages > 1)
    {
        <div class="favs-pagination">
            <Pagination ActivePageNumber="@_currentPage"
                        TotalPages="@TotalPages"
                        DisplayPages="7"
                        Alignment="Alignment.Center"
                        PreviousLinkText="Prev"
                        NextLinkText="Next"
                        PageChanged="OnPageChangedAsync" />
        </div>
    }
}

@code {
    private const int PageSize = 18;
    private const int Columns = 6;

    private List<FavouritesViewModel> _allFavourites = [];
    private List<FavouritesViewModel> _filteredFavourites = [];
    private int _currentPage = 1;

    private string _selectedOrder = string.Empty;
    private string _selectedFamily = string.Empty;

    private List<string> _availableOrders = [];
    private List<string> _availableFamilies = [];

    private int TotalPages => (int)Math.Ceiling(_filteredFavourites.Count / (double)PageSize);

    private IEnumerable<FavouritesViewModel> CurrentPageItems =>
        _filteredFavourites
            .Skip((_currentPage - 1) * PageSize)
            .Take(PageSize);

    protected override async Task OnInitializedAsync()
    {
        var response = await Http.GetFromJsonAsync<IEnumerable<FavouritesViewModel>>("favourites");
        _allFavourites = response?.ToList() ?? [];
        _filteredFavourites = _allFavourites.ToList();

        UpdateAvailableFilters();
    }

    private void UpdateAvailableFilters()
    {
        // Get all unique orders
        _availableOrders = _allFavourites
            .Select(f => f.Order)
            .Distinct()
            .OrderBy(o => o)
            .ToList();

        // Update families based on selected order
        if (string.IsNullOrEmpty(_selectedOrder))
        {
            _availableFamilies = _allFavourites
                .Select(f => f.Family)
                .Distinct()
                .OrderBy(f => f)
                .ToList();
        }
        else
        {
            _availableFamilies = _allFavourites
                .Where(f => f.Order == _selectedOrder)
                .Select(f => f.Family)
                .Distinct()
                .OrderBy(f => f)
                .ToList();
        }
    }

    private async Task OnOrderChangedAsync(ChangeEventArgs e)
    {
        _selectedOrder = e.Value?.ToString() ?? string.Empty;
        _selectedFamily = string.Empty; // Reset family when order changes
        _currentPage = 1; // Reset to first page

        UpdateAvailableFilters();
        ApplyFilters();

        await Task.CompletedTask;
    }

    private async Task OnFamilyChangedAsync(ChangeEventArgs e)
    {
        _selectedFamily = e.Value?.ToString() ?? string.Empty;
        _currentPage = 1; // Reset to first page

        ApplyFilters();

        await Task.CompletedTask;
    }

    private void ApplyFilters()
    {
        _filteredFavourites = _allFavourites
            .Where(f => string.IsNullOrEmpty(_selectedOrder) || f.Order == _selectedOrder)
            .Where(f => string.IsNullOrEmpty(_selectedFamily) || f.Family == _selectedFamily)
            .ToList();
    }

    private Task OnPageChangedAsync(int newPageNumber)
    {
        var normalizedPageNumber = Math.Clamp(newPageNumber, 1, Math.Max(1, TotalPages));
        _currentPage = normalizedPageNumber;
        return Task.CompletedTask;
    }
}
